# Suraksh — Environment Variables Example
# Copy this file to .env and fill in real values before running.

APP_NAME=Suraksh
APP_VERSION=0.1.0
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local development:
DATABASE_URL=sqlite:///./suraksh.db
# PostgreSQL / Supabase (production):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/suraksh_db

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION_USE_A_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list — update to match your frontend origin.
ALLOWED_ORIGINS=["http://localhost:3000"]
